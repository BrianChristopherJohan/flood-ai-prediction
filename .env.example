# Copy this file to .env and fill in real values
# Never commit .env to git
# Service: flood-ai-prediction — Port 8000 (local) / Railway injects PORT

# ── Server ────────────────────────────────────────────────────────────────────
# Railway injects PORT at runtime — do not hard-code it here.
# The Dockerfile CMD uses ${PORT:-8000} so this is only needed for local dev.
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Railway: set to your actual frontend/backend Railway domains, e.g.:
#   ALLOWED_ORIGINS=https://flood-community.up.railway.app,https://flood-crm.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,exp://localhost:8081

# ── Model paths ───────────────────────────────────────────────────────────────
# Paths are relative to /app inside the container.
# Models are trained during Docker build (scripts/train.py) — do not change.
MODEL_PATH=models/flood_model.pkl
SCALER_PATH=models/scaler.pkl
